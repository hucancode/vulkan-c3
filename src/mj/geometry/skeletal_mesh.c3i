module mj;
import std::collections::map;

def SkeletalMeshHandle = usz;
def BoneHandle = usz;

struct Bone {
    Transform transform;
    BoneHandle[] children;
}

struct SkeletalMesh {
    SkinnedVertex[] vertices;
    uint[] indices;
    Bone[] bones;
    HashMap(<String, AnimationTrack>) animations;
}
